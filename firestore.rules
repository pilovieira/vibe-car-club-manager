rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
  
  	function isAuth() {
    	return request.auth != null;
    }
    
    // Helper function to check if the user is an admin
    function isAdmin() {
      return isAuth() && 
             get(/databases/$(database)/documents/members/$(request.auth.uid)).data.role == 'admin';
    }
    
    match /members/{memberId} {
      // Allow reading member info if authenticated OR if viewing public event context
      // Simplified: allow read for everyone but only for specific fields would be better,
      // but Firestore rules are limited. We'll allow read if authenticated or via a public check.
      // For now, allow read for public to support avatars in public events.
      allow read: if true; 
      
     // Create Rule:
      allow create: if isAuth() && (
        isAdmin() || 
        (
          request.auth.uid == memberId && 
          request.resource.data.role == 'member'
        )
      );
      
      // Update Logic:
      allow update: if isAuth() && (
        isAdmin() || 
        (
          request.auth.uid == memberId && 
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role'])
        )
      );
    }
    
    // Properties / Settings
    match /properties/{propertyId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Events & Core data
    match /events/{eventId} {
      allow read: if isAuth() || resource.data.visibility == 'public';
      allow write: if isAdmin();
    }
    
    match /event_attendees/{id} {
      // Allow reading attendees if authenticated OR if the event is public
      allow read: if isAuth() || get(/databases/$(database)/documents/events/$(resource.data.event_id)).data.visibility == 'public';
      allow create: if isAuth() && (request.resource.data.member_id == request.auth.uid || isAdmin());
      allow delete: if isAuth() && (resource.data.member_id == request.auth.uid || isAdmin());
    }

    match /event_photos/{photoId} {
      // Allow reading photos if authenticated OR if the event is public
      allow read: if isAuth() || get(/databases/$(database)/documents/events/$(resource.data.event_id)).data.visibility == 'public';
      allow create: if isAuth() && request.resource.data.uploaded_by_id == request.auth.uid;
      allow delete: if isAuth() && (resource.data.uploaded_by_id == request.auth.uid || isAdmin());
      allow update: if false;
    }

    match /contributions/{id} {
      allow read: if isAuth() && (resource.data.member_id == request.auth.uid || isAdmin());
      allow write: if isAdmin();
    }
    
    match /global_transactions/{id} {
      allow read, write: if isAdmin();
    }

    match /pages/{pageId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // LogBook collection
    match /logs/{logId} {
      allow read: if isAdmin();
      allow create: if isAuth();
      allow update, delete: if false;
    }
  }
}